PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://127.0.0.1:27017/novaschool_os

# JWT: replace both values with independent random secrets of at least 32 characters.
JWT_ACCESS_SECRET=replace_with_a_random_access_secret_32_chars_minimum
JWT_REFRESH_SECRET=replace_with_a_random_refresh_secret_32_chars_minimum

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Angular client and refresh-token cookie
CLIENT_URL=http://127.0.0.1:4200
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false
# COOKIE_DOMAIN=

# Initial administrator (only used by npm run seed:admin)
ADMIN_NAME=
ADMIN_USERNAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=
